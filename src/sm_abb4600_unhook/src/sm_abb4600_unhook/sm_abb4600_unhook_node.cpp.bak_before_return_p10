class StWaitManualTarget : public smacc2::SmaccState<StWaitManualTarget, SmAbb4600Unhook>
{
public:
  using SmaccState::SmaccState;

  typedef mpl::list<
    smacc2::Transition<EvManualTargetReceived, StMoveToManualTarget>,
    smacc2::Transition<EvManualTargetInvalid, StError>
  > reactions;

  void onEntry()
  {
    RCLCPP_WARN(logger(), "[StWaitManualTarget] 等待人工输入坐标 /abb4600_unhook/manual_target");
    RCLCPP_WARN(logger(), "示例：ros2 topic pub -1 /abb4600_unhook/manual_target geometry_msgs/msg/PointStamped \"{header: {frame_id: 'base_link'}, point: {x: 1.594, y: 0.819, z: 1.050}}\"");

    auto node = this->getNode();

    target_sub_ = node->create_subscription<geometry_msgs::msg::PointStamped>(
      "/abb4600_unhook/manual_target", rclcpp::QoS(10),
      [this](geometry_msgs::msg::PointStamped::SharedPtr msg)
      {
        auto & sm = this->context<SmAbb4600Unhook>();

        if (!msg->header.frame_id.empty() && msg->header.frame_id != "base_link") {
          std::ostringstream err;
          err << "manual_target frame_id must be base_link, got: " << msg->header.frame_id;
          sm.setLastError(err.str());
          RCLCPP_ERROR(logger(), "%s", err.str().c_str());
          this->postEvent<EvManualTargetInvalid>();
          return;
        }

        const double x = msg->point.x;
        const double y = msg->point.y;
        const double z = msg->point.z;

        std::string reason;
        if (!sm.validateTarget(x, y, z, reason)) {
          std::ostringstream err;
          err << "Invalid manual target x=" << x << " y=" << y << " z=" << z
              << ", reason=" << reason;
          sm.setLastError(err.str());
          RCLCPP_ERROR(logger(), "%s", err.str().c_str());
          this->postEvent<EvManualTargetInvalid>();
          return;
        }

        sm.setTarget(x, y, z);

        RCLCPP_WARN(
          logger(),
          "[StWaitManualTarget] accepted target: x=%.3f y=%.3f z=%.3f m",
          x, y, z);

        this->postEvent<EvManualTargetReceived>();
      });
  }

private:
  rclcpp::Subscription<geometry_msgs::msg::PointStamped>::SharedPtr target_sub_;
};

class StMoveToManualTarget : public smacc2::SmaccState<StMoveToManualTarget, SmAbb4600Unhook>
{
public:
  using SmaccState::SmaccState;

  typedef mpl::list<
    smacc2::Transition<EvActionSucceeded, StExecutePresetUnhookPath>,
    smacc2::Transition<EvActionFailed, StError>
  > reactions;

  void onEntry()
  {
    auto node = this->getNode();
    action_client_ = rclcpp_action::create_client<RunRobotPath>(node, "/abb4600/run_robot_path");

    double x, y, z;
    auto & sm = this->context<SmAbb4600Unhook>();
    sm.getTarget(x, y, z);

    const double x_mm = x * 1000.0;
    const double y_mm = y * 1000.0;
    const double z_mm = z * 1000.0;

    const std::string path_name = sm.makeSafeTcpBaseMmPath(x_mm, y_mm, z_mm);
    RCLCPP_WARN(logger(), "[StMoveToManualTarget] send goal: %s", path_name.c_str());

    sendGoal(path_name);
  }

private:
  rclcpp_action::Client<RunRobotPath>::SharedPtr action_client_;

  void sendGoal(const std::string & path_name)
  {
    if (!action_client_->wait_for_action_server(5s)) {
      auto & sm = this->context<SmAbb4600Unhook>();
      sm.setLastError("Move to target failed: action server not available.");
      this->postEvent<EvActionFailed>();
      return;
    }

    auto goal = makeGoal(path_name);
    auto options = rclcpp_action::Client<RunRobotPath>::SendGoalOptions();

    options.goal_response_callback =
      [this](std::shared_ptr<GoalHandleRunRobotPath> goal_handle)
      {
        if (!goal_handle) {
          auto & sm = this->context<SmAbb4600Unhook>();
          sm.setLastError("Move to target failed: goal rejected.");
          this->postEvent<EvActionFailed>();
        }
      };

    options.feedback_callback =
      [](GoalHandleRunRobotPath::SharedPtr, const std::shared_ptr<const RunRobotPath::Feedback> fb)
      {
        RCLCPP_INFO(
          logger(),
          "[StMoveToManualTarget feedback] %.2f %s",
          fb->progress,
          fb->current_stage.c_str());
      };

    options.result_callback =
      [this](const GoalHandleRunRobotPath::WrappedResult & result)
      {
        auto & sm = this->context<SmAbb4600Unhook>();

        if (result.code != rclcpp_action::ResultCode::SUCCEEDED || !result.result) {
          sm.setLastError("Move to target failed: action did not finish with SUCCEEDED.");
          this->postEvent<EvActionFailed>();
          return;
        }

        if (!result.result->success) {
          sm.setLastError("Move to target failed: " + result.result->message);
          this->postEvent<EvActionFailed>();
          return;
        }

        RCLCPP_WARN(logger(), "[StMoveToManualTarget] succeeded: %s", result.result->message.c_str());
        this->postEvent<EvActionSucceeded>();
      };

    action_client_->async_send_goal(goal, options);
  }
};

class StExecutePresetUnhookPath : public smacc2::SmaccState<StExecutePresetUnhookPath, SmAbb4600Unhook>
{
public:
  using SmaccState::SmaccState;

  typedef mpl::list<
    smacc2::Transition<EvActionSucceeded, StWaitManualVerify>,
    smacc2::Transition<EvActionFailed, StError>
  > reactions;

  void onEntry()
  {
    auto node = this->getNode();
    action_client_ = rclcpp_action::create_client<RunRobotPath>(node, "/abb4600/run_robot_path");

    RCLCPP_WARN(logger(), "[StExecutePresetUnhookPath] 预设摘钩路径：z+80mm，然后 x-120mm");
    executeStep1();
  }

private:
  rclcpp_action::Client<RunRobotPath>::SharedPtr action_client_;

  void executeStep1()
  {
    double x, y, z;
    auto & sm = this->context<SmAbb4600Unhook>();
    sm.getTarget(x, y, z);

    const double x_mm = x * 1000.0;
    const double y_mm = y * 1000.0;
    const double z_mm = z * 1000.0 + SmAbb4600Unhook::kLiftZMm;

    const std::string path_name = sm.makeSafeTcpBaseMmPath(x_mm, y_mm, z_mm);

    RCLCPP_WARN(logger(), "[StExecutePresetUnhookPath] step1: %s", path_name.c_str());

    sendGoal(
      path_name,
      [this](bool success, const std::string & message)
      {
        if (!success) {
          auto & sm = this->context<SmAbb4600Unhook>();
          sm.setLastError("Preset unhook step1 failed: " + message);
          this->postEvent<EvActionFailed>();
          return;
        }

        RCLCPP_WARN(logger(), "[StExecutePresetUnhookPath] step1 succeeded");
        executeStep2();
      });
  }

  void executeStep2()
  {
    double x, y, z;
    auto & sm = this->context<SmAbb4600Unhook>();
    sm.getTarget(x, y, z);

    const double x_mm = x * 1000.0 + SmAbb4600Unhook::kRetreatXMm;
    const double y_mm = y * 1000.0;
    const double z_mm = z * 1000.0 + SmAbb4600Unhook::kLiftZMm;

    const std::string path_name = sm.makeSafeTcpBaseMmPath(x_mm, y_mm, z_mm);

    RCLCPP_WARN(logger(), "[StExecutePresetUnhookPath] step2: %s", path_name.c_str());

    sendGoal(
      path_name,
      [this](bool success, const std::string & message)
      {
        if (!success) {
          auto & sm = this->context<SmAbb4600Unhook>();
          sm.setLastError("Preset unhook step2 failed: " + message);
          this->postEvent<EvActionFailed>();
          return;
        }

        RCLCPP_WARN(logger(), "[StExecutePresetUnhookPath] preset path finished");
        this->postEvent<EvActionSucceeded>();
      });
  }

  void sendGoal(
    const std::string & path_name,
    std::function<void(bool, const std::string &)> done_cb)
  {
    if (!action_client_->wait_for_action_server(5s)) {
      done_cb(false, "action server not available");
      return;
    }

    auto goal = makeGoal(path_name);
    auto options = rclcpp_action::Client<RunRobotPath>::SendGoalOptions();

    options.goal_response_callback =
      [done_cb](std::shared_ptr<GoalHandleRunRobotPath> goal_handle)
      {
        if (!goal_handle) {
          done_cb(false, "goal rejected");
        }
      };

    options.feedback_callback =
      [](GoalHandleRunRobotPath::SharedPtr, const std::shared_ptr<const RunRobotPath::Feedback> fb)
      {
        RCLCPP_INFO(
          logger(),
          "[PresetUnhook feedback] %.2f %s",
          fb->progress,
          fb->current_stage.c_str());
      };

    options.result_callback =
      [done_cb](const GoalHandleRunRobotPath::WrappedResult & result)
      {
        if (result.code != rclcpp_action::ResultCode::SUCCEEDED || !result.result) {
          done_cb(false, "action did not finish with SUCCEEDED");
          return;
        }

        done_cb(result.result->success, result.result->message);
      };

    action_client_->async_send_goal(goal, options);
  }
};

