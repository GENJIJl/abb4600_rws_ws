class StWaitSystemReady : public smacc2::SmaccState<StWaitSystemReady, SmAbb4600Unhook>
{
public:
  using SmaccState::SmaccState;

  typedef mpl::list<
    smacc2::Transition<EvSystemReady, StSafetyCheck>,
    smacc2::Transition<EvSystemNotReady, StError>
  > reactions;

  void onEntry()
  {
    RCLCPP_WARN(logger(), "[StWaitSystemReady] 检查 /abb4600/run_robot_path action server");

    auto node = this->getNode();
    action_client_ = rclcpp_action::create_client<RunRobotPath>(node, "/abb4600/run_robot_path");

    timer_ = node->create_wall_timer(
      500ms,
      [this]()
      {
        check_count_++;

        if (action_client_->wait_for_action_server(0ms)) {
          RCLCPP_WARN(logger(), "[StWaitSystemReady] action server ready");
          this->postEvent<EvSystemReady>();
          return;
        }

        if (check_count_ >= 20) {
          auto & sm = this->context<SmAbb4600Unhook>();
          sm.setLastError("System not ready: /abb4600/run_robot_path action server not available.");
          RCLCPP_ERROR(logger(), "[StWaitSystemReady] action server not available");
          this->postEvent<EvSystemNotReady>();
        }
      });
  }

private:
  int check_count_{0};
  rclcpp_action::Client<RunRobotPath>::SharedPtr action_client_;
  rclcpp::TimerBase::SharedPtr timer_;
};

class StSafetyCheck : public smacc2::SmaccState<StSafetyCheck, SmAbb4600Unhook>
{
public:
  using SmaccState::SmaccState;

  typedef mpl::list<
    smacc2::Transition<EvSafetyOk, StWaitOperatorConfirm>,
    smacc2::Transition<EvSafetyFailed, StError>
  > reactions;

  void onEntry()
  {
    RCLCPP_WARN(logger(), "[StSafetyCheck] 检查 /joint_states");

    auto node = this->getNode();

    joint_sub_ = node->create_subscription<sensor_msgs::msg::JointState>(
      "/joint_states", rclcpp::QoS(10),
      [this](sensor_msgs::msg::JointState::SharedPtr msg)
      {
        if (done_) {
          return;
        }

        if (msg->name.size() < 6 || msg->position.size() < 6) {
          return;
        }

        for (double p : msg->position) {
          if (!std::isfinite(p)) {
            auto & sm = this->context<SmAbb4600Unhook>();
            sm.setLastError("Safety check failed: joint_states contains NaN or Inf.");
            done_ = true;
            this->postEvent<EvSafetyFailed>();
            return;
          }
        }

        RCLCPP_WARN(logger(), "[StSafetyCheck] joint_states ok");
        done_ = true;
        this->postEvent<EvSafetyOk>();
      });

    timeout_timer_ = node->create_wall_timer(
      5s,
      [this]()
      {
        if (done_) {
          return;
        }

        auto & sm = this->context<SmAbb4600Unhook>();
        sm.setLastError("Safety check failed: no valid /joint_states within 5 seconds.");
        RCLCPP_ERROR(logger(), "[StSafetyCheck] no valid /joint_states");
        done_ = true;
        this->postEvent<EvSafetyFailed>();
      });
  }

private:
  bool done_{false};
  rclcpp::Subscription<sensor_msgs::msg::JointState>::SharedPtr joint_sub_;
  rclcpp::TimerBase::SharedPtr timeout_timer_;
};

