int main(int argc, char * argv[])
{
  rclcpp::init(argc, argv);

  auto node = std::make_shared<rclcpp::Node>(
    "execute_path10_moveit_node",
    rclcpp::NodeOptions().automatically_declare_parameters_from_overrides(true));

  rclcpp::executors::SingleThreadedExecutor executor;
  executor.add_node(node);
  std::thread spinner([&executor]() { executor.spin(); });

  static constexpr char kGroupName[] = "manipulator";
  moveit::planning_interface::MoveGroupInterface move_group(node, kGroupName);
  move_group.setEndEffectorLink("tool0");
  move_group.setPoseReferenceFrame("base_link");
  const double velocity_scale = getOrDeclareDouble(node, "velocity_scale", 0.02);
  const double acceleration_scale = getOrDeclareDouble(node, "acceleration_scale", 0.02);
  move_group.setMaxVelocityScalingFactor(velocity_scale);
  move_group.setMaxAccelerationScalingFactor(acceleration_scale);
  move_group.setPlanningTime(getOrDeclareDouble(node, "planning_time", 10.0));

  const auto targets = path10Targets();
  RCLCPP_INFO(node->get_logger(), "准备执行 Path_10，共 %zu 个 RAPID 目标点。", targets.size());

  std::vector<geometry_msgs::msg::Pose> waypoints;
  waypoints.reserve(targets.size());
  for (const auto & target : targets) {
    waypoints.push_back(toTool0Pose(target));
  }

  move_group.setStartStateToCurrentState();
  move_group.setPoseTarget(waypoints.front(), "tool0");

  moveit::planning_interface::MoveGroupInterface::Plan first_plan;
  const auto first_plan_result = move_group.plan(first_plan);
  if (first_plan_result != moveit::core::MoveItErrorCode::SUCCESS) {
    RCLCPP_ERROR(node->get_logger(), "无法规划到 Path_10 起点 Target_210。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }

  RCLCPP_INFO(node->get_logger(), "正在运动到 Path_10 起点 Target_210。");
  if (move_group.execute(first_plan) != moveit::core::MoveItErrorCode::SUCCESS) {
    RCLCPP_ERROR(node->get_logger(), "执行起点轨迹失败。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }

  std::vector<geometry_msgs::msg::Pose> cartesian_waypoints(waypoints.begin() + 1, waypoints.end() - 1);
  moveit_msgs::msg::RobotTrajectory cartesian_trajectory;
  const double eef_step = getOrDeclareDouble(node, "eef_step", 0.02);
  const double fraction =
    move_group.computeCartesianPath(
      cartesian_waypoints,
      eef_step,
      0.0,
      cartesian_trajectory,
      true,
      nullptr);

  RCLCPP_INFO(node->get_logger(), "笛卡尔路径规划完成比例：%.2f%%", fraction * 100.0);
  if (fraction < getOrDeclareDouble(node, "minimum_cartesian_fraction", 0.90)) {
    RCLCPP_ERROR(node->get_logger(), "笛卡尔路径规划比例不足，停止执行。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }

  robot_trajectory::RobotTrajectory retimed_trajectory(move_group.getRobotModel(), kGroupName);
  const auto current_state = move_group.getCurrentState(2.0);
  if (!current_state) {
    RCLCPP_ERROR(node->get_logger(), "无法读取当前机器人状态，不能给笛卡尔轨迹重新生成时间戳。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }
  retimed_trajectory.setRobotTrajectoryMsg(*current_state, cartesian_trajectory);

  trajectory_processing::TimeOptimalTrajectoryGeneration time_parameterization;
  if (!time_parameterization.computeTimeStamps(
        retimed_trajectory, velocity_scale, acceleration_scale))
  {
    RCLCPP_ERROR(node->get_logger(), "笛卡尔轨迹时间参数化失败。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }
  retimed_trajectory.getRobotTrajectoryMsg(cartesian_trajectory);

  RCLCPP_INFO(node->get_logger(), "正在执行 Path_10 笛卡尔轨迹。");
  if (move_group.execute(cartesian_trajectory) != moveit::core::MoveItErrorCode::SUCCESS) {
    RCLCPP_ERROR(node->get_logger(), "执行 Path_10 笛卡尔轨迹失败。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }

  if (!getOrDeclareBool(node, "return_to_target_210", true)) {
    RCLCPP_INFO(node->get_logger(), "已按参数设置跳过自动回到 Target_210，避免回程穿过 RobotStudio 场景物体。");
    RCLCPP_INFO(node->get_logger(), "Path_10 执行完成。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 0;
  }

  move_group.setStartStateToCurrentState();
  move_group.setPoseTarget(waypoints.back(), "tool0");

  moveit::planning_interface::MoveGroupInterface::Plan return_plan;
  const auto return_plan_result = move_group.plan(return_plan);
  if (return_plan_result != moveit::core::MoveItErrorCode::SUCCESS) {
    RCLCPP_ERROR(node->get_logger(), "无法规划回 Path_10 起点 Target_210。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }

  RCLCPP_INFO(node->get_logger(), "正在回到 Path_10 起点 Target_210。");
  if (move_group.execute(return_plan) != moveit::core::MoveItErrorCode::SUCCESS) {
    RCLCPP_ERROR(node->get_logger(), "执行回到 Target_210 的轨迹失败。");
    executor.cancel();
    spinner.join();
    rclcpp::shutdown();
    return 1;
  }

  RCLCPP_INFO(node->get_logger(), "Path_10 执行完成。");
  executor.cancel();
  spinner.join();
  rclcpp::shutdown();
  return 0;
}
