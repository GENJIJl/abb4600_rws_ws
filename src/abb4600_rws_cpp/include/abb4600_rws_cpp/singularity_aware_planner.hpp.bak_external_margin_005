inline std::string getWorkspaceRoot()
{
  const char * home = std::getenv("HOME");
  if (home != nullptr) {
    return std::string(home) + "/abb4600_rws_ws";
  }

  return "/home/gen/abb4600_rws_ws";
}

inline std::string getIkDebugDirectory()
{
  return getWorkspaceRoot() + "/experiment_logs/ik_debug";
}

inline std::string getIkLatestCsvPath()
{
  return getIkDebugDirectory() + "/ik_candidates_latest.csv";
}

inline std::string getIkAllCsvPath()
{
  return getIkDebugDirectory() + "/ik_candidates_all.csv";
}

inline std::string csvEscape(const std::string & value)
{
  bool need_quote = false;

  for (const char c : value) {
    if (c == ',' || c == '"' || c == '\n' || c == '\r') {
      need_quote = true;
      break;
    }
  }

  if (!need_quote) {
    return value;
  }

  std::string out = "\"";
  for (const char c : value) {
    if (c == '"') {
      out += "\"\"";
    } else {
      out += c;
    }
  }
  out += "\"";

  return out;
}

inline double getJointOrZero(
  const std::map<std::string, double> & q,
  const std::string & joint_name)
{
  auto it = q.find(joint_name);
  if (it == q.end()) {
    return 0.0;
  }

  return it->second;
}

inline double minDistanceToSafeBoundary(
  const std::map<std::string, double> & q)
{
  double min_distance = std::numeric_limits<double>::infinity();

  for (const auto & item : q) {
    const auto & joint_name = item.first;
    const double value = item.second;

    const double d = distanceToSafeBoundary(joint_name, value);
    if (d < min_distance) {
      min_distance = d;
    }
  }

  return min_distance;
}

inline double jointDistanceFromPrevious(
  const std::map<std::string, double> & q_prev,
  const std::map<std::string, double> & q)
{
  double sum = 0.0;

  for (const auto & item : q) {
    auto prev_it = q_prev.find(item.first);
    if (prev_it == q_prev.end()) {
      continue;
    }

    const double dq = item.second - prev_it->second;
    sum += dq * dq;
  }

  return std::sqrt(sum);
}

inline double maxJointJumpFromPrevious(
  const std::map<std::string, double> & q_prev,
  const std::map<std::string, double> & q)
{
  double max_jump = 0.0;

  for (const auto & item : q) {
    auto prev_it = q_prev.find(item.first);
    if (prev_it == q_prev.end()) {
      continue;
    }

    const double jump = std::abs(item.second - prev_it->second);
    if (jump > max_jump) {
      max_jump = jump;
    }
  }

  return max_jump;
}

inline std::string jointMapToCsvValues(
  const std::map<std::string, double> & q)
{
  std::ostringstream oss;
  oss << std::fixed << std::setprecision(9)
      << getJointOrZero(q, "joint_1") << ","
      << getJointOrZero(q, "joint_2") << ","
      << getJointOrZero(q, "joint_3") << ","
      << getJointOrZero(q, "joint_4") << ","
      << getJointOrZero(q, "joint_5") << ","
      << getJointOrZero(q, "joint_6");

  return oss.str();
}

inline std::string ikCandidateCsvHeader()
{
  return
    "target_name,"
    "candidate_id,"
    "source,"
    "joint_1,"
    "joint_2,"
    "joint_3,"
    "joint_4,"
    "joint_5,"
    "joint_6,"
    "q5_abs,"
    "min_boundary_distance,"
    "joint_distance,"
    "max_joint_jump,"
    "has_joint_wrap_risk,"
    "has_joint_jump_risk,"
    "total_cost,"
    "accepted,"
    "reject_reason,"
    "selected\n";
}

inline void resetIkCandidateLatestCsv()
{
  std::filesystem::create_directories(getIkDebugDirectory());

  std::ofstream latest(getIkLatestCsvPath(), std::ios::trunc);
  if (!latest.is_open()) {
    return;
  }

  latest << ikCandidateCsvHeader();
}

inline void ensureIkAllCsvHasHeader()
{
  std::filesystem::create_directories(getIkDebugDirectory());

  const std::string all_path = getIkAllCsvPath();
  const bool exists = std::filesystem::exists(all_path);
  const bool empty = exists && std::filesystem::file_size(all_path) == 0;

  if (!exists || empty) {
    std::ofstream all(all_path, std::ios::app);
    if (all.is_open()) {
      all << ikCandidateCsvHeader();
    }
  }
}

inline void appendIkCandidateDebugCsvToFile(
  const std::string & file_path,
  const std::string & target_name,
  const int candidate_id,
  const std::string & source,
  const std::map<std::string, double> & q_prev,
  const std::map<std::string, double> & q,
  const bool accepted,
  const std::string & reject_reason,
  const bool selected,
  const double total_cost)
{
  std::ofstream out(file_path, std::ios::app);
  if (!out.is_open()) {
    return;
  }

  const double q5 = getJointOrZero(q, "joint_5");
  const double q5_abs = std::abs(q5);
  const double min_boundary_distance = minDistanceToSafeBoundary(q);
  const double joint_distance = jointDistanceFromPrevious(q_prev, q);
  const double max_joint_jump = maxJointJumpFromPrevious(q_prev, q);
  const bool wrap_risk = hasJointWrapRisk(q_prev, q);
  const bool jump_risk = hasJointJumpRisk(q_prev, q);

  out << csvEscape(target_name) << ","
      << candidate_id << ","
      << csvEscape(source) << ","
      << jointMapToCsvValues(q) << ","
      << std::fixed << std::setprecision(9)
      << q5_abs << ","
      << min_boundary_distance << ","
      << joint_distance << ","
      << max_joint_jump << ","
      << (wrap_risk ? "true" : "false") << ","
      << (jump_risk ? "true" : "false") << ","
      << total_cost << ","
      << (accepted ? "true" : "false") << ","
      << csvEscape(reject_reason) << ","
      << (selected ? "true" : "false")
      << "\n";
}

inline void appendIkCandidateDebugCsv(
  const std::string & target_name,
  const int candidate_id,
  const std::string & source,
  const std::map<std::string, double> & q_prev,
  const std::map<std::string, double> & q,
  const bool accepted,
  const std::string & reject_reason,
  const bool selected,
  const double total_cost)
{
  std::filesystem::create_directories(getIkDebugDirectory());
  ensureIkAllCsvHasHeader();

  appendIkCandidateDebugCsvToFile(
    getIkLatestCsvPath(),
    target_name,
    candidate_id,
    source,
    q_prev,
    q,
    accepted,
    reject_reason,
    selected,
    total_cost);

  appendIkCandidateDebugCsvToFile(
    getIkAllCsvPath(),
    target_name,
    candidate_id,
    source,
    q_prev,
    q,
    accepted,
    reject_reason,
    selected,
    total_cost);
}

// 多 seed IK 筛选：核心函数
inline SafeIkResult solveSafeIkForPose(
  moveit::planning_interface::MoveGroupInterface & move_group,
  const geometry_msgs::msg::Pose & target_pose,
  const std::map<std::string, double> & q_prev,
  const std::string & eef_link,
  const double ik_timeout = 0.20,
  const std::string & target_name = "unknown_target")
{
  SafeIkResult best;

  // 每次求一个目标点时，latest 文件清空重写。
  // all 文件持续追加，方便保存整个实验过程。
  resetIkCandidateLatestCsv();
  ensureIkAllCsvHasHeader();

  auto current_state = move_group.getCurrentState(2.0);
  if (!current_state) {
    best.message = "Failed to get current robot state.";
    return best;
  }

  const auto * jmg = current_state->getJointModelGroup(move_group.getName());
  if (!jmg) {
    best.message = "Failed to get JointModelGroup.";
    return best;
  }

  const std::vector<std::string> joint_names = jmg->getVariableNames();

  std::vector<double> q_seed;
  q_seed.reserve(joint_names.size());

  for (const auto & joint_name : joint_names) {
    auto it = q_prev.find(joint_name);
    if (it != q_prev.end()) {
      q_seed.push_back(it->second);
    } else {
      q_seed.push_back(0.0);
    }
  }

  auto clampOne = [](const std::string & joint_name, const double value) {
    auto lim_it = kAbb4600SafeLimits.find(joint_name);
    if (lim_it == kAbb4600SafeLimits.end()) {
      return value;
    }

    return std::max(
      lim_it->second.lower + 0.02,
      std::min(lim_it->second.upper - 0.02, value));
  };

  auto normalizeMapNearPrevious =
    [&](std::map<std::string, double> q) {
      for (const auto & joint_name : {"joint_4", "joint_6"}) {
        auto prev_it = q_prev.find(joint_name);
        auto curr_it = q.find(joint_name);

        if (prev_it == q_prev.end() || curr_it == q.end()) {
          continue;
        }

        curr_it->second = normalizeNear(prev_it->second, curr_it->second);
        curr_it->second = clampOne(joint_name, curr_it->second);
      }

      return q;
    };

  auto clampSeed = [&](std::vector<double> seed) {
    for (size_t i = 0; i < joint_names.size(); ++i) {
      seed[i] = clampOne(joint_names[i], seed[i]);
    }
    return seed;
  };

  std::vector<std::vector<double>> seeds;

  // 1. 上一安全构型作为主 seed
  seeds.push_back(clampSeed(q_seed));

  // 2. 当前真实状态作为辅助 seed
  std::vector<double> q_current;
  current_state->copyJointGroupPositions(jmg, q_current);
  seeds.push_back(clampSeed(q_current));

  // 3. 对每个关节做扰动
  for (size_t i = 0; i < q_seed.size(); ++i) {
    for (double delta : {0.20, -0.20, 0.50, -0.50}) {
      auto seed = q_seed;
      seed[i] += delta;
      seeds.push_back(clampSeed(seed));
    }
  }

  // 4. 重点扰动 joint_5，避开腕部奇异
  for (double q5_seed : {0.35, -0.35, 0.60, -0.60, 1.0, -1.0, 1.5, -1.5}) {
    auto seed = q_seed;

    for (size_t i = 0; i < joint_names.size(); ++i) {
      if (joint_names[i] == "joint_5") {
        seed[i] = q5_seed;
      }
    }

    seeds.push_back(clampSeed(seed));
  }

  // 5. 重点扰动 joint_4
  for (double j4_delta : {M_PI / 2.0, -M_PI / 2.0, M_PI, -M_PI}) {
    auto seed = q_seed;

    for (size_t i = 0; i < joint_names.size(); ++i) {
      if (joint_names[i] == "joint_4") {
        seed[i] += j4_delta;
      }
    }

    seeds.push_back(clampSeed(seed));
  }

  // 6. 重点扰动 joint_6
  for (double j6_delta : {M_PI / 2.0, -M_PI / 2.0, M_PI, -M_PI}) {
    auto seed = q_seed;

    for (size_t i = 0; i < joint_names.size(); ++i) {
      if (joint_names[i] == "joint_6") {
        seed[i] += j6_delta;
      }
    }

    seeds.push_back(clampSeed(seed));
  }

  int ik_success_count = 0;
  int accepted_count = 0;
  int rejected_count = 0;
  int wrist_flip_count = 0;
  int candidate_id = 0;
  int best_candidate_id = -1;
  std::string best_source;
  std::string last_reject_reason;

  auto tryCandidate =
    [&](std::map<std::string, double> q_map, const std::string & source) {
      const int this_candidate_id = candidate_id++;

      q_map = normalizeMapNearPrevious(q_map);

      bool accepted = true;
      std::string reject_reason;

      // 关键规则：
      // 如果上一安全构型 joint_5 是正，目标 IK 也优先保持正；
      // 如果上一安全构型 joint_5 是负，目标 IK 也优先保持负。
      // 这样可以避免关节空间轨迹中 joint_5 穿过 0。
      auto prev_q5_it = q_prev.find("joint_5");
      auto curr_q5_it = q_map.find("joint_5");

      if (prev_q5_it != q_prev.end() && curr_q5_it != q_map.end()) {
        if (prev_q5_it->second * curr_q5_it->second < 0.0) {
          accepted = false;
          reject_reason = "joint_5 sign changed, path would cross wrist singularity.";
        }
      }

      if (accepted && rejectUnsafeIk(q_map, reject_reason)) {
        accepted = false;
      }

      double cost = std::numeric_limits<double>::infinity();

      if (accepted) {
        cost = safeIkCost(q_prev, q_map);
        accepted_count++;

        if (cost < best.cost) {
          best.success = true;
          best.cost = cost;
          best.joint_target = q_map;
          best.message = "Safe IK found from " + source;
          best_candidate_id = this_candidate_id;
          best_source = source;
        }
      } else {
        rejected_count++;
        last_reject_reason = source + ": " + reject_reason;
      }

      appendIkCandidateDebugCsv(
        target_name,
        this_candidate_id,
        source,
        q_prev,
        q_map,
        accepted,
        reject_reason,
        false,
        cost);
    };

  auto makeWristFlip =
    [&](const std::map<std::string, double> & q_map) {
      auto q_flip = q_map;

      if (q_flip.find("joint_4") != q_flip.end() &&
          q_flip.find("joint_5") != q_flip.end() &&
          q_flip.find("joint_6") != q_flip.end())
      {
        q_flip["joint_4"] = q_flip["joint_4"] + M_PI;
        q_flip["joint_5"] = -q_flip["joint_5"];
        q_flip["joint_6"] = q_flip["joint_6"] + M_PI;
      }

      q_flip = normalizeMapNearPrevious(q_flip);

      for (auto & item : q_flip) {
        item.second = clampOne(item.first, item.second);
      }

      return q_flip;
    };

  for (const auto & seed : seeds) {
    moveit::core::RobotState state(*current_state);
    state.setJointGroupPositions(jmg, seed);
    state.enforceBounds();
    state.update();

    const bool ik_ok = state.setFromIK(jmg, target_pose, eef_link, ik_timeout);
    if (!ik_ok) {
      continue;
    }

    ik_success_count++;

    std::vector<double> q_values;
    state.copyJointGroupPositions(jmg, q_values);

    auto q_map = vectorToJointMap(joint_names, q_values);

    // 原始 IK 候选
    tryCandidate(q_map, "raw_ik");

    // 腕部翻转等价 IK 候选：
    // q4' = q4 + pi
    // q5' = -q5
    // q6' = q6 + pi
    auto q_flip = makeWristFlip(q_map);
    wrist_flip_count++;
    tryCandidate(q_flip, "wrist_flip_ik");
  }

  if (!best.success) {
    std::ostringstream oss;
    oss << "No safe IK found. "
        << "ik_success_count=" << ik_success_count
        << ", accepted_count=" << accepted_count
        << ", rejected_count=" << rejected_count
        << ", wrist_flip_count=" << wrist_flip_count;

    if (!last_reject_reason.empty()) {
      oss << ", last_reject_reason=" << last_reject_reason;
    }

    best.message = oss.str();
  } else {
    // 追加一条 selected_best 记录，明确最终选中的 IK 解。
    appendIkCandidateDebugCsv(
      target_name,
      best_candidate_id,
      "selected_best_from_" + best_source,
      q_prev,
      best.joint_target,
      true,
      "",
      true,
      best.cost);

    std::ostringstream oss;
    oss << best.message
        << ", best_candidate_id=" << best_candidate_id
        << ", best_cost=" << best.cost
        << ", ik_success_count=" << ik_success_count
        << ", accepted_count=" << accepted_count
        << ", rejected_count=" << rejected_count
        << ", wrist_flip_count=" << wrist_flip_count
        << ", ik_debug_latest=" << getIkLatestCsvPath();

    best.message = oss.str();
  }

  return best;
}

inline TrajectoryRisk analyzeTrajectoryRisk(
  const trajectory_msgs::msg::JointTrajectory & traj)
{
  TrajectoryRisk risk;

  if (traj.joint_names.empty()) {
    risk.type = TrajectoryRiskType::INVALID;
    risk.message = "trajectory joint_names is empty.";
    return risk;
  }

  if (traj.points.empty()) {
    risk.type = TrajectoryRiskType::INVALID;
    risk.message = "trajectory points is empty.";
    return risk;
  }

  std::map<std::string, size_t> index;
  for (size_t i = 0; i < traj.joint_names.size(); ++i) {
    index[traj.joint_names[i]] = i;
  }

  for (size_t p = 0; p < traj.points.size(); ++p) {
    const auto & point = traj.points[p];

    for (const auto & item : kAbb4600SafeLimits) {
      const auto idx_it = index.find(item.first);
      if (idx_it == index.end()) {
        continue;
      }

      const double q = point.positions[idx_it->second];

      if (!insideSafeRange(item.first, q)) {
        std::ostringstream oss;
        oss << "external singularity: point " << p
            << ", " << item.first << " = " << q
            << " outside safe range.";
        risk.type = TrajectoryRiskType::EXTERNAL_SINGULARITY;
        risk.message = oss.str();
        risk.point_index = p;
        risk.joint_name = item.first;
        risk.value = q;
        return risk;
      }

      if (distanceToSafeBoundary(item.first, q) < kExternalBoundaryMargin) {
        std::ostringstream oss;
        oss << "external singularity warning: point " << p
            << ", " << item.first << " = " << q
            << " near safe boundary external_margin_0.07.";
        risk.type = TrajectoryRiskType::EXTERNAL_SINGULARITY;
        risk.message = oss.str();
        risk.point_index = p;
        risk.joint_name = item.first;
        risk.value = q;
        return risk;
      }
    }

    const auto q5_idx = index.find("joint_5");
    if (q5_idx != index.end()) {
      const double q5 = point.positions[q5_idx->second];

      if (std::abs(q5) < kInternalSingularityDanger) {
        std::ostringstream oss;
        oss << "internal singularity: point " << p
            << ", joint_5 = " << q5;
        risk.type = TrajectoryRiskType::INTERNAL_SINGULARITY;
        risk.message = oss.str();
        risk.point_index = p;
        risk.joint_name = "joint_5";
        risk.value = q5;
        return risk;
      }
    }

    if (p > 0) {
      const auto & prev = traj.points[p - 1];

      for (size_t j = 0; j < traj.joint_names.size(); ++j) {
        const double dq = std::abs(point.positions[j] - prev.positions[j]);

        if (dq > kMaxJointJump) {
          std::ostringstream oss;
          oss << "joint jump: segment " << p - 1 << " -> " << p
              << ", " << traj.joint_names[j]
              << ", dq = " << dq;
          risk.type = TrajectoryRiskType::JOINT_JUMP;
          risk.message = oss.str();
          risk.point_index = p;
          risk.joint_name = traj.joint_names[j];
          risk.value = dq;
          return risk;
        }
      }
    }
  }

  risk.type = TrajectoryRiskType::SAFE;
  risk.message = "trajectory is safe.";
  return risk;
}

// 外部奇异回退构型
inline std::map<std::string, double> makeBoundaryRetreatTarget(
  const std::map<std::string, double> & q_last_safe)
{
  std::map<std::string, double> q_recover = q_last_safe;

  for (auto & item : q_recover) {
    const std::string & name = item.first;
    double & q = item.second;

    auto lim_it = kAbb4600SafeLimits.find(name);
    if (lim_it == kAbb4600SafeLimits.end()) {
      continue;
    }

    const auto & lim = lim_it->second;

    if (q > lim.upper - kExternalBoundaryMargin) {
      q -= 0.20;
    }

    if (q < lim.lower + kExternalBoundaryMargin) {
      q += 0.20;
    }

    q = std::max(lim.lower + 0.20, std::min(lim.upper - 0.20, q));
  }

  return q_recover;
}

